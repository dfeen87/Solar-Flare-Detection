# Downloaded data files — fetched at runtime from NOAA SWPC
assets/data/**/*.json

# Long-range cached GOES JSON — fetched at runtime from NOAA SWPC
data/raw/goes/**/*.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
.env
.venv
venv/
env/

# Jupyter
.ipynb_checkpoints/

# Generated figures and outputs
domains/*/examples_python/output/*.png
domains/*/examples_python/output/*.pdf
domains/*/examples_python/output/*.svg

# Top-level pipeline output — synthetic pipeline outputs are not committed,
# but paper_figures/ artifacts are tracked so that publication-ready figures,
# CSV tables, and the PDF report are available directly from the repository.
output/**
!output/paper_figures/
!output/paper_figures/**
!output/synthetic_pipeline/
!output/synthetic_pipeline/.gitkeep

# Experiment result artifacts — generated at runtime by experiments/
results/**
!results/.keep

# macOS
.DS_Store

# Julia
Manifest.toml
